DATABASE_URL=postgresql://luxledger:luxledger@127.0.0.1:5432/luxledger
DATABASE_URL_TEST=postgresql://luxledger:luxledger@127.0.0.1:5433/luxledger_demo_test
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=20
DB_CONNECT_TIMEOUT=10
NODE_ENV=development
PORT=3000
SHUTDOWN_TIMEOUT_MS=10000
# Demo-only one-shot bootstrap. Replace the key before any shared deployment.
BOOTSTRAP_TENANT_NAME=Demo tenant
BOOTSTRAP_ADMIN_KEY_NAME=Initial admin key
BOOTSTRAP_ADMIN_API_KEY=ll_demo_admin_change_me
# 32+ random bytes encoded as unpadded base64url. Example generation:
# openssl rand -base64 32 | tr '+/' '-_' | tr -d '=\n'
JWT_SIGNING_KEY=REPLACE_WITH_BASE64URL_32_BYTE_SECRET
JWT_PREVIOUS_SIGNING_KEYS=
JWT_ISSUER=luxledger-api
JWT_ACCESS_TTL_SECONDS=900
JWT_CLOCK_SKEW_SECONDS=5
RATE_LIMIT_AUTH_TOKEN_MAX_REQUESTS=20
RATE_LIMIT_AUTH_TOKEN_WINDOW_SECONDS=60
RATE_LIMIT_WRITE_MAX_REQUESTS=120
RATE_LIMIT_WRITE_WINDOW_SECONDS=60
